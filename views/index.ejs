<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Supermarket App - Products</title>

    <!-- Bootstrap CSS & JS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <style>
        table {
            width: 100%;
            border-collapse: collapse;
            font-family: sans-serif;
        }
        th, td {
            padding: 12px;
            text-align: center;
            border-bottom: 1px solid #ddd;
            vertical-align: middle;
        }
        th {
            font-weight: bold;
            background-color: #f8f9fa;
        }
        .product-img {
            max-width: 80px;
            height: auto;
            object-fit: cover;
        }
    </style>
</head>
<body class="bg-light">

    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">🛒 Supermarket App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link" href="/addProduct">Add New Product</a>
            </li> 
          </ul>
        </div>
      </div>
    </nav>

    <!-- Main Content Container -->
    <div class="container mt-5">
        <div class="card shadow p-4 bg-white">
            <h1 class="mb-4 text-secondary text-center">Products Database</h1>

            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Product Name</th>
                            <th>Product Image</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Edit</th>
                            <th>Delete</th>
                        </tr>
                    </thead>
                    
                    <tbody>
                        <% for(let i=0; i < products.length; i++) { %>
                            <tr>
                                <!-- Product Name Link -->
                                <td>
                                    <a href="/product/<%= products[i].productId %>" class="text-decoration-none fw-bold">
                                        <%= products[i].productName %>
                                    </a>
                                </td>
                                
                                <!-- Product Image -->
                                <td>
                                    <img src= "images/<%= products[i].image %>" width = "20%">
                                </td>
                                
                                <!-- Quantity -->
                                <td><%= products[i].quantity %></td>
                                
                                <!-- Price formatted to 2 decimal places -->
                                <td>$<%= products[i].price.toFixed(2) %></td>
                                
                                <!-- Edit Link -->
                                <td>
                                    <a href="/editProduct/<%= products[i].productId %>" class="btn btn-sm btn-outline-warning">Edit</a>
                                </td>
                                
                                <!-- INTEGRATED: Delete Link with confirmation dialog -->
                                <td>
                                    <a href="/deleteProduct/<%= products[i].productId %>" 
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Are you sure you want to delete this product?')">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div> 
        </div>
    </div>

</body>
</html>